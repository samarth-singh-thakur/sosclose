#!/bin/zsh
# SOSCLOSE - Safe multi-mode macOS tidy-up script for pre-call cleanup.

set +e
setopt typesetsilent

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

SCRIPT_VERSION="1.0.0"
LOG_FILE=""

QUIT_GRACE=2
TERM_TIMEOUT=4
KILL_TIMEOUT=2

PORT_TERM_TIMEOUT=3
PORT_KILL_TIMEOUT=2

PROTECTED_APPS_BASE=(
  "Terminal"
  "iTerm2"
  "Dock"
  "SystemUIServer"
  "Finder"
)

PROTECTED_APPS_CALL_EXTRA=(
  "zoom.us"
  "Microsoft Teams"
  "Google Chrome"
  "Safari"
  "FaceTime"
)

DEV_APPS=(
  "Visual Studio Code"
  "Xcode"
  "IntelliJ IDEA"
  "WebStorm"
  "PyCharm"
  "Android Studio"
  "Docker Desktop"
  "Postman"
)

PORTS_CALL=(3000 5173 8000 8080 8081)
PORTS_DEV_WEB=(3000 3001 4000 5000 5173 5500 5678 8000 8080 8081 9000 9229)
PORTS_DEV_DATA=(5432 6379 27017 9200)

DEV_PROCESS_PATTERNS=(
  "vite"
  "react-scripts"
  "next[[:space:]]dev"
  "webpack-dev-server"
  "nodemon"
  "python[[:space:]].*-m[[:space:]]http\\.server"
  "uvicorn"
  "gunicorn"
  "django.*runserver"
  "rails[[:space:]]server"
  "kubectl[[:space:]]proxy"
  "docker-compose"
)

MODE=""
MODE_NAME=""
DRY_RUN=0

KEEP_APPS=()
PROTECTED_APPS=()
PORTS_TO_STOP=()

DO_CLOSE_FINDER_WINDOWS=0
DO_HIDE_DESKTOP_ICONS=0
DO_MINIMISE_WINDOWS=0
DO_CLOSE_VISIBLE_APPS=0
DO_CLOSE_DEV_APPS=0
DO_STOP_PORTS=0
DO_STOP_PROCS=0
PERMISSION_WARNED=0

pick_log_file() {
  local candidate=""

  for candidate in \
    "${HOME}/sosclose.log" \
    "${SCRIPT_DIR}/sosclose.log" \
    "${TMPDIR:-/tmp}/sosclose.log"
  do
    if touch "$candidate" >/dev/null 2>&1; then
      LOG_FILE="$candidate"
      return 0
    fi
  done

  print -u2 "ERROR: Could not create a log file."
  exit 1
}

pick_log_file
exec > >(tee -a "$LOG_FILE") 2>&1

ts() {
  date "+%Y-%m-%dT%H:%M:%S%z"
}

log() {
  local level="$1"
  shift
  printf "[%s] %-7s %s\n" "$(ts)" "$level" "$*"
}

die() {
  log "ERROR" "$*"
  exit 1
}

warn_permissions_once() {
  if (( PERMISSION_WARNED )); then
    return 0
  fi

  PERMISSION_WARNED=1
  log "WARN" "macOS may be blocking app control. If apps are not closing, allow your terminal in System Settings > Privacy & Security > Automation and Accessibility."
}

trim() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  print -r -- "$s"
}

escape_applescript_string() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  print -r -- "$s"
}

normalise_app_name() {
  local raw
  raw="$(trim "$1")"
  local key="${raw:l}"

  case "$key" in
    slack) print -r -- "Slack" ;;
    teams|msteams|"microsoft teams") print -r -- "Microsoft Teams" ;;
    zoom|"zoom.us") print -r -- "zoom.us" ;;
    chrome|"google chrome") print -r -- "Google Chrome" ;;
    safari) print -r -- "Safari" ;;
    finder) print -r -- "Finder" ;;
    terminal) print -r -- "Terminal" ;;
    iterm|iterm2) print -r -- "iTerm2" ;;
    vscode|code|"visual studio code") print -r -- "Visual Studio Code" ;;
    *)
      print -r -- "$raw"
      ;;
  esac
}

array_contains_ci() {
  local needle="${1:l}"
  shift
  local item
  for item in "$@"; do
    if [[ "${item:l}" == "$needle" ]]; then
      return 0
    fi
  done
  return 1
}

is_app_running() {
  local app="$1"
  get_app_pids "$app" >/dev/null
}

is_protected_app() {
  local app="$1"
  local canon
  canon="$(normalise_app_name "$app")"
  array_contains_ci "$canon" "${PROTECTED_APPS[@]}" && return 0
  array_contains_ci "$canon" "${KEEP_APPS[@]}" && return 0
  return 1
}

wait_for_pid_exit() {
  local pid="$1"
  local timeout="$2"
  local i=0

  while (( i < timeout )); do
    if ! kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
    sleep 1
    (( i++ ))
  done

  return 1
}

staged_kill_pid() {
  local pid="$1"
  local label="$2"
  local term_timeout="${3:-$TERM_TIMEOUT}"
  local kill_timeout="${4:-$KILL_TIMEOUT}"

  if ! kill -0 "$pid" 2>/dev/null; then
    log "INFO" "PID already gone: ${label} pid=${pid}"
    return 0
  fi

  if (( DRY_RUN )); then
    log "DRYRUN" "Would SIGTERM then SIGKILL (if needed): ${label} pid=${pid}"
    return 0
  fi

  log "TERM" "SIGTERM -> ${label} pid=${pid}"
  kill -TERM "$pid" 2>/dev/null
  wait_for_pid_exit "$pid" "$term_timeout" && return 0

  log "KILL" "SIGKILL (last resort) -> ${label} pid=${pid}"
  kill -KILL "$pid" 2>/dev/null
  wait_for_pid_exit "$pid" "$kill_timeout" && return 0

  if kill -0 "$pid" 2>/dev/null; then
    log "WARN" "Process still running after SIGKILL: ${label} pid=${pid}"
  fi
}

request_app_quit() {
  local app="$1"
  local escaped
  escaped="$(escape_applescript_string "$app")"

  if (( DRY_RUN )); then
    log "DRYRUN" "Would request quit via AppleScript: ${app}"
    return 0
  fi

  local output=""
  output="$(osascript -e "tell application \"${escaped}\" to quit" 2>&1)"
  if [[ $? -ne 0 ]]; then
    log "WARN" "AppleScript quit failed for ${app}: ${output}"
    warn_permissions_once
    return 1
  fi

  return 0
}

get_app_pids() {
  local app="$1"
  local canon
  canon="$(normalise_app_name "$app")"

  local pids=""
  pids="$(pgrep -ix "$canon" 2>/dev/null)"
  if [[ -n "$pids" ]]; then
    print -r -- "$pids"
    return 0
  fi

  local escaped
  escaped="$(escape_applescript_string "$canon")"

  pids="$(osascript <<APPLESCRIPT 2>/dev/null
tell application "System Events"
  try
    set pidList to unix id of every application process whose name is "${escaped}"
    if (count of pidList) is 0 then
      return ""
    end if
    return pidList as string
  on error
    return ""
  end try
end tell
APPLESCRIPT
)"

  if [[ -n "$pids" ]]; then
    pids="${pids//,/ }"
    print -r -- "$pids"
    return 0
  fi

  pids="$(pgrep -if "/${canon// /.*}\.app/" 2>/dev/null)"
  if [[ -n "$pids" ]]; then
    print -r -- "$pids"
    return 0
  fi

  return 1
}

close_app_staged() {
  local app="$1"
  local canon
  canon="$(normalise_app_name "$app")"

  if is_protected_app "$canon"; then
    log "SKIP" "Protected/kept app: ${canon}"
    return 0
  fi

  if ! is_app_running "$canon"; then
    return 0
  fi

  log "QUIT" "Requesting quit: ${canon}"
  request_app_quit "$canon"
  sleep "$QUIT_GRACE"

  local pids
  pids="$(get_app_pids "$canon" 2>/dev/null)"
  if [[ -n "$pids" ]]; then
    local pid
    for pid in ${(ps: :)pids}; do
      staged_kill_pid "$pid" "$canon"
    done
  fi
}

close_apps_batch() {
  local requested_apps=("$@")
  local target_apps=()
  local app

  for app in "${requested_apps[@]}"; do
    app="$(normalise_app_name "$app")"
    [[ -z "$app" ]] && continue

    if is_protected_app "$app"; then
      log "SKIP" "Protected/kept app: ${app}"
      continue
    fi

    if ! is_app_running "$app"; then
      continue
    fi

    target_apps+=("$app")
  done

  if (( ${#target_apps[@]} == 0 )); then
    return 0
  fi

  for app in "${target_apps[@]}"; do
    log "QUIT" "Requesting quit: ${app}"
    request_app_quit "$app"
  done

  sleep "$QUIT_GRACE"

  for app in "${target_apps[@]}"; do
    local pids
    pids="$(get_app_pids "$app" 2>/dev/null)"
    [[ -z "$pids" ]] && continue

    local pid
    for pid in ${(ps: :)pids}; do
      staged_kill_pid "$pid" "$app"
    done
  done
}

join_apps_csv() {
  local app
  local out=""

  for app in "$@"; do
    [[ -z "$app" ]] && continue
    if [[ -n "$out" ]]; then
      out+=","
    fi
    out+="$app"
  done

  print -r -- "$out"
}

get_visible_gui_apps_csv() {
  local output=""
  output="$(osascript <<'APPLESCRIPT' 2>&1
tell application "System Events"
  set appList to {}
  repeat with procRef in (every application process whose background only is false)
    try
      set end of appList to (name of procRef) as text
    end try
  end repeat
  return appList
end tell
APPLESCRIPT
)"
  if [[ $? -ne 0 ]]; then
    log "WARN" "Could not query visible apps via System Events: ${output}"
    warn_permissions_once
    return 1
  fi

  local apps=()
  local line=""

  while IFS= read -r line; do
    line="$(trim "$line")"
    [[ -z "$line" ]] && continue
    apps+=("$line")
  done <<< "$output"

  if (( ${#apps[@]} == 0 )); then
    return 0
  fi

  join_apps_csv "${apps[@]}"
}

close_visible_gui_apps() {
  local csv
  csv="$(get_visible_gui_apps_csv 2>/dev/null)"
  if [[ -z "$csv" ]]; then
    log "WARN" "No visible GUI apps were returned by System Events."
    return 0
  fi

  local apps=()
  local app
  for app in ${(s:,:)csv}; do
    app="$(trim "$app")"
    [[ -z "$app" ]] && continue
    apps+=("$app")
  done

  close_apps_batch "${apps[@]}"
}

close_finder_windows() {
  if (( DRY_RUN )); then
    log "DRYRUN" "Would close Finder windows"
    return 0
  fi

  local output=""
  output="$(osascript -e 'tell application "Finder" to close every window' 2>&1)"
  if [[ $? -ne 0 ]]; then
    log "WARN" "Could not close Finder windows: ${output}"
    warn_permissions_once
    return 1
  fi

  log "INFO" "Closed Finder windows (best effort)"
}

set_desktop_icons_hidden() {
  if (( DRY_RUN )); then
    log "DRYRUN" "Would hide desktop icons (defaults write + restart Finder)"
    return 0
  fi

  local current
  current="$(defaults read com.apple.finder CreateDesktop 2>/dev/null)"
  if [[ -z "$current" ]]; then
    current="(unset -> default shown)"
  fi

  log "INFO" "Desktop icon preference before: CreateDesktop=${current}"
  defaults write com.apple.finder CreateDesktop -bool false >/dev/null 2>&1
  killall Finder >/dev/null 2>&1
  log "INFO" "Desktop icons hidden (persistent) - revert: defaults write com.apple.finder CreateDesktop -bool true; killall Finder"
}

minimise_app_windows_best_effort() {
  local app="$1"
  local escaped
  escaped="$(escape_applescript_string "$app")"

  if (( DRY_RUN )); then
    log "DRYRUN" "Would attempt to minimise windows via System Events: ${app}"
    return 0
  fi

  local output=""
  output="$(osascript -e "tell application \"System Events\" to tell process \"${escaped}\" to set value of attribute \"AXMinimized\" of every window to true" 2>&1)"
  if [[ $? -ne 0 ]]; then
    log "WARN" "Could not minimise windows for ${app}: ${output}"
    warn_permissions_once
    return 1
  fi

  log "INFO" "Attempted to minimise windows (best effort): ${app}"
}

should_skip_by_keep_pattern() {
  local hay="${1:l}"
  local token

  for token in "${KEEP_APPS[@]}"; do
    local needle="${token:l}"
    [[ -z "$needle" ]] && continue
    if [[ "$hay" == *"$needle"* ]]; then
      return 0
    fi
  done

  return 1
}

stop_listening_port() {
  local port="$1"
  local pids

  pids="$(lsof -nP -iTCP:"$port" -sTCP:LISTEN -t 2>/dev/null)"
  [[ -z "$pids" ]] && return 0

  local pid
  for pid in ${(f)pids}; do
    [[ -z "$pid" ]] && continue

    local cmd
    cmd="$(ps -p "$pid" -o command= 2>/dev/null)"
    [[ -z "$cmd" ]] && cmd="(unknown)"

    if should_skip_by_keep_pattern "$cmd"; then
      log "SKIP" "Port ${port}: kept by pattern pid=${pid} cmd=${cmd}"
      continue
    fi

    log "PORT" "Stopping port ${port} pid=${pid} cmd=${cmd}"
    staged_kill_pid "$pid" "port:${port}" "$PORT_TERM_TIMEOUT" "$PORT_KILL_TIMEOUT"
  done
}

stop_ports() {
  local port
  for port in "$@"; do
    stop_listening_port "$port"
  done
}

stop_dev_process_patterns() {
  local pattern
  for pattern in "${DEV_PROCESS_PATTERNS[@]}"; do
    local pids
    pids="$(pgrep -f "$pattern" 2>/dev/null)"
    [[ -z "$pids" ]] && continue

    local pid
    for pid in ${(f)pids}; do
      [[ -z "$pid" ]] && continue

      local cmd
      cmd="$(ps -p "$pid" -o command= 2>/dev/null)"
      [[ -z "$cmd" ]] && cmd="(unknown)"

      if should_skip_by_keep_pattern "$cmd"; then
        log "SKIP" "Dev pattern '${pattern}': kept by keep token pid=${pid} cmd=${cmd}"
        continue
      fi

      log "PROC" "Stopping dev process (pattern='${pattern}') pid=${pid} cmd=${cmd}"
      staged_kill_pid "$pid" "pattern:${pattern}"
    done
  done
}

usage() {
  cat <<EOF
SOSCLOSE ${SCRIPT_VERSION}

Usage:
  ./SOSCLOSE
  ./SOSCLOSE -m 2
  ./SOSCLOSE --mode 1 --keep slack --keep teams
  ./SOSCLOSE --dry-run --keep "Google Chrome"

Options:
  -m, --mode N        Mode number: 1 (Call), 2 (Dev cleanup), 3 (Aggressive), 4 (Custom)
  --keep APP          Protect an app from being quit/killed (repeatable)
  --dry-run           Print what would happen, but do not change state
  --help              Show this help

Notes:
  - macOS may show Automation prompts the first time Terminal controls an app.
  - UI scripting actions may require Accessibility permission.
EOF
}

select_mode_interactive() {
  print -r -- "Choose mode:"
  print -r -- "  1) Call mode - close Finder windows, hide desktop icons, quit visible apps, stop common web dev ports"
  print -r -- "  2) Dev cleanup - quit dev apps, stop web dev ports, stop common dev processes"
  print -r -- "  3) Aggressive (Fresh start) - broader app closing, stop web + datastore ports"
  print -r -- "  4) Custom cleanup - choose actions interactively"
  print -n -- "Press Enter for default [1]: "

  local choice=""
  read -r choice
  MODE="${choice:-1}"
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -m|--mode)
        [[ -z "${2:-}" ]] && die "--mode requires an argument"
        MODE="$2"
        shift 2
        ;;
      --mode=*)
        MODE="${1#*=}"
        shift
        ;;
      --keep)
        [[ -z "${2:-}" ]] && die "--keep requires an argument"
        KEEP_APPS+=("$(normalise_app_name "$2")")
        shift 2
        ;;
      --keep=*)
        KEEP_APPS+=("$(normalise_app_name "${1#*=}")")
        shift
        ;;
      --dry-run|-n)
        DRY_RUN=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "Unknown option: $1 (use --help)"
        ;;
    esac
  done
}

build_mode_plan() {
  PROTECTED_APPS=("${PROTECTED_APPS_BASE[@]}")
  PORTS_TO_STOP=()

  DO_CLOSE_FINDER_WINDOWS=0
  DO_HIDE_DESKTOP_ICONS=0
  DO_MINIMISE_WINDOWS=0
  DO_CLOSE_VISIBLE_APPS=0
  DO_CLOSE_DEV_APPS=0
  DO_STOP_PORTS=0
  DO_STOP_PROCS=0

  case "$MODE" in
    1)
      MODE_NAME="Call mode"
      PROTECTED_APPS+=("${PROTECTED_APPS_CALL_EXTRA[@]}")
      DO_CLOSE_FINDER_WINDOWS=1
      DO_HIDE_DESKTOP_ICONS=1
      DO_CLOSE_VISIBLE_APPS=1
      DO_STOP_PORTS=1
      PORTS_TO_STOP=("${PORTS_CALL[@]}")
      ;;
    2)
      MODE_NAME="Dev cleanup"
      DO_CLOSE_DEV_APPS=1
      DO_STOP_PORTS=1
      DO_STOP_PROCS=1
      PORTS_TO_STOP=("${PORTS_DEV_WEB[@]}")
      ;;
    3)
      MODE_NAME="Aggressive cleanup (Fresh start)"
      DO_CLOSE_FINDER_WINDOWS=1
      DO_HIDE_DESKTOP_ICONS=1
      DO_CLOSE_VISIBLE_APPS=1
      DO_STOP_PORTS=1
      DO_STOP_PROCS=1
      PORTS_TO_STOP=("${PORTS_DEV_WEB[@]}" "${PORTS_DEV_DATA[@]}")
      ;;
    4)
      MODE_NAME="Custom cleanup"

      if [[ ! -t 0 ]]; then
        log "WARN" "Custom mode selected without a TTY; no prompts available. Doing nothing."
        return 0
      fi

      local ans=""
      local port_token=""

      print -n -- "Close Finder windows? [Y/n]: "
      read -r ans
      ans="${ans:-Y}"
      [[ "${ans:l}" == "y" ]] && DO_CLOSE_FINDER_WINDOWS=1

      print -n -- "Hide desktop icons (persistent until reverted)? [y/N]: "
      read -r ans
      ans="${ans:-N}"
      [[ "${ans:l}" == "y" ]] && DO_HIDE_DESKTOP_ICONS=1

      print -n -- "Minimise visible app windows (best effort)? [y/N]: "
      read -r ans
      ans="${ans:-N}"
      [[ "${ans:l}" == "y" ]] && DO_MINIMISE_WINDOWS=1

      print -n -- "Quit visible GUI apps (except protected/kept)? [y/N]: "
      read -r ans
      ans="${ans:-N}"
      [[ "${ans:l}" == "y" ]] && DO_CLOSE_VISIBLE_APPS=1

      print -n -- "Stop listening ports? Enter comma-separated values or press Enter for none: "
      read -r ans
      if [[ -n "$(trim "$ans")" ]]; then
        DO_STOP_PORTS=1
        for port_token in ${(s:,:)ans}; do
          port_token="$(trim "$port_token")"
          [[ "$port_token" == <-> ]] && PORTS_TO_STOP+=("$port_token")
        done
      fi

      print -n -- "Stop common dev process patterns (vite/uvicorn/etc.)? [y/N]: "
      read -r ans
      ans="${ans:-N}"
      [[ "${ans:l}" == "y" ]] && DO_STOP_PROCS=1
      ;;
  esac
}

run_mode() {
  log "START" "SOSCLOSE v${SCRIPT_VERSION} mode=${MODE} (${MODE_NAME}) dry_run=${DRY_RUN}"
  log "START" "Protected apps: ${PROTECTED_APPS[*]}"
  if (( ${#KEEP_APPS[@]} > 0 )); then
    log "START" "Keep apps: ${KEEP_APPS[*]}"
  else
    log "START" "Keep apps: (none)"
  fi

  if (( DO_CLOSE_FINDER_WINDOWS )); then
    close_finder_windows
  fi

  if (( DO_HIDE_DESKTOP_ICONS )); then
    set_desktop_icons_hidden
  fi

  if (( DO_MINIMISE_WINDOWS )); then
    local csv
    csv="$(get_visible_gui_apps_csv 2>/dev/null)"
    if [[ -n "$csv" ]]; then
      local app
      for app in ${(s:,:)csv}; do
        app="$(trim "$app")"
        [[ -z "$app" ]] && continue
        if is_protected_app "$app"; then
          log "SKIP" "Minimise: protected/kept app: ${app}"
        else
          minimise_app_windows_best_effort "$app"
        fi
      done
    fi
  fi

  if (( DO_CLOSE_DEV_APPS )); then
    close_apps_batch "${DEV_APPS[@]}"
  fi

  if (( DO_CLOSE_VISIBLE_APPS )); then
    close_visible_gui_apps
  fi

  if (( DO_STOP_PORTS )) && (( ${#PORTS_TO_STOP[@]} > 0 )); then
    stop_ports "${PORTS_TO_STOP[@]}"
  fi

  if (( DO_STOP_PROCS )); then
    stop_dev_process_patterns
  fi

  log "DONE" "Completed SOSCLOSE run."
  log "DONE" "Log file: ${LOG_FILE}"
}

main() {
  parse_args "$@"

  if [[ -z "$MODE" ]]; then
    if [[ -t 0 ]]; then
      select_mode_interactive
    else
      MODE="1"
      log "WARN" "No --mode provided and no TTY available; defaulting to mode 1"
    fi
  fi

  case "$MODE" in
    1|2|3|4) ;;
    *)
      die "Invalid mode: ${MODE} (expected 1..4)"
      ;;
  esac

  build_mode_plan
  run_mode
}

main "$@"
